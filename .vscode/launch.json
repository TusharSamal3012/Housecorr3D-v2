    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
    
        // od3d_dataset visualize --config configs/housecorr3d_object.yaml --render-frames 6 --renderer pyrender
        // od3d_dataset visualize --config third_party/od3d-dataset/configs/housecorr3d_object.yaml --render-frames 6 --renderer pyrender
        // python third_party/od3d-dataset/src/od3d_dataset/__main__.py visualize --config third_party/od3d-dataset/configs/housecorr3d_object.yaml --render-frames 6 --renderer pyrender
        {            
            "name": "Visualize HouseCorr3D Object",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/third_party/od3d-dataset/src/od3d_dataset/__main__.py",
            "args": [
                "visualize",
                "--config", "${workspaceFolder}/third_party/od3d-dataset/configs/housecorr3d_object.yaml",
                "--render-frames", "6",
                "--renderer", "pyrender"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "o3b dataset viz hc3d_object",
            "type": "debugpy",
            "request": "launch",
            "module": "o3b.cli",
            "args": [
                "dataset", "viz",
                "-d", "hc3d_object"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv/bin/python3"
        }
    ]
}